{
  "name": "tehillim-app",
  "version": "1.0.0",
  "description": "Hebrew Psalms (Tehillim) web app with AI-powered analysis",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "cd client && npx vite --host",
    "dev:server": "cd server && npx tsx watch index.ts",
    "build:client": "cd client && npx vite build",
    "build": "npm run build:client",
    "start": "cd server && node --import tsx index.ts",
    "precache": "npx tsx server/scripts/precache-analyses.ts",
    "postinstall": "cd client && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.1",
    "@types/helmet": "^0.0.48",
    "better-sqlite3": "^11.7.0",
    "canvas-confetti": "^1.9.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^13.6.1",
    "helmet": "^8.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/canvas-confetti": "^1.9.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
